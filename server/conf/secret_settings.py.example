"""
Local secrets and environment-specific overrides.

This file is intentionally NOT committed as `secret_settings.py`.
Copy this file to `secret_settings.py` and adjust values as needed.

Usage:
  cp server/conf/secret_settings.py.example server/conf/secret_settings.py

Used for:
- Local development
- API keys
- Host configuration
- Non-portable overrides
"""

# --------------------------------------------------
# Django secret key (randomize for production)
# --------------------------------------------------

# Generate one: python -c "from django.core.secretkey import get_secret_key; print(get_secret_key())"
SECRET_KEY='ReplaceWithYourSecretKey'

# --------------------------------------------------
# Starting position
# --------------------------------------------------

# DB ID of the room where new characters spawn (default: Limbo #2)
STARTING_POSITION_ID = 25  # e.g., Holodeck Arch

# --------------------------------------------------
# LLM / AI configuration
# --------------------------------------------------

# Local LLM endpoint (vLLM, LM Studio, etc.)
LOCAL_BASE_URL = "http://127.0.0.1:30001/v1"
LOCAL_MODEL = "/models/qwen3-14b-nvfp4"

# Remote OpenAI-compatible fallback (optional)
# OPENAI_BASE_URL = "https://api.openai.com/v1"
# OPENAI_MODEL = "gpt-4.1-mini"
# OPENAI_API_KEY = "sk-..."

# LLM timeout in seconds
# LLM_TIMEOUT_S = 180

# --------------------------------------------------
# Image generation (FLUX.2 REST backend)
# --------------------------------------------------

# The image_generation module reads the FLUX2_SERVER_URL environment
# variable. You can also set it in the Evennia startup script or in
# a `.env` file (loaded by the Evennia server).
#
# Example:
#   export FLUX2_SERVER_URL="http://your-flux-server:8190"
#
# The default is the link-local DGX Spark GPU node:
#   http://169.254.209.73:8190
#
# Image generation is triggered automatically by SmartRoom on desc
# rewrites, and by the `regen` command (builder lock).

# --------------------------------------------------
# Debug / development toggles
# --------------------------------------------------

# Uncomment for extra verbosity during development
# DEBUG = True

# Example: extend INSTALLED_APPS locally
# INSTALLED_APPS += ["debug_toolbar"]
