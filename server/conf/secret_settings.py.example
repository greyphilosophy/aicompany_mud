    "backend": {
        "backend": "flux2_rest",
        "options": {
            "server_url": "http://169.254.209.73:8190",
            "output_dir": "generated",
            "media_url_base": "https://your-domain.com/media/generated",
            "timeout_s": 120.0,
            "default_steps": 50,
            "default_guidance_scale": 11.0,
            "default_width": 1536,
            "default_height": 1024,
        },
